# Copy to .env for local dev. In Replit, set these as Secrets instead of a
# .env file (see README "Running locally in Replit").

# --- Database (Neon Postgres) ------------------------------------------
# Full connection string from your Neon project, e.g.:
# postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=

# --- GitHub Models (LLM provider) --------------------------------------
# A GitHub personal access token with the "Models" permission.
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# --- Rate limiting -------------------------------------------------------
MAX_REQUESTS_PER_MINUTE=10
MAX_CONCURRENT_REQUESTS=2
MAX_RETRIES=3
BASE_BACKOFF_SECONDS=5

# --- Follow-up scheduler --------------------------------------------------
FOLLOWUP_BATCH_DELAY_SECONDS=3
FOLLOWUP_SCAN_HOUR_UTC=3

# --- Research cache ---------------------------------------------------------
RESEARCH_CACHE_TTL_DAYS=7

# --- Chatwoot (omni-channel hub) -- leave disabled until you have an account
CHATWOOT_ENABLED=false
CHATWOOT_BASE_URL=
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_WEBHOOK_SECRET=

# --- App -------------------------------------------------------------------
ADMIN_SESSION_SECRET=change-me
ENVIRONMENT=development
